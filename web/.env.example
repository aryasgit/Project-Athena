# Point this at your Postgres / Supabase database.
# Supabase: Project Settings -> Database -> Connection string (use the pooled
# "Transaction" connection string for serverless / Vercel).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# The active analytics module (matches the pipeline's ATHENA_MODULE).
NEXT_PUBLIC_MODULE=placement

# --- AI Intelligence layer (optional) --------------------------------------
# Athena is deterministic-first: it works fully with NONE of these set. The AI
# layer only rewrites narrative prose over the structured analytics.
#
# AI_PROVIDER: ollama | openrouter | openai | anthropic | gemini  (unset = off)
# AI_MODEL:    override the default model for the chosen provider.
AI_PROVIDER=
AI_MODEL=

# Ollama (primary, local). Default base URL shown.
OLLAMA_BASE_URL=http://localhost:11434

# Cloud providers (only the key for your chosen AI_PROVIDER is needed).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
